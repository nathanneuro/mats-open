<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.SignalBoost" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryDark">@color/accent_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnPrimary">@color/text_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:statusBarColor">@color/surface</item>
        <item name="android:navigationBarColor">@color/surface</item>
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="Theme.SignalBoost.Alarm" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">@color/alarm_red</item>
        <item name="android:statusBarColor">@color/alarm_red</item>
        <item name="android:navigationBarColor">@color/alarm_red</item>
        <item name="android:windowFullscreen">true</item>
    </style>

</resources>
